# Copy to .env for local dev. Never commit .env.

# Required — Twilio credentials (from twilio.com console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+18005551234

# Required — Flask session signing key
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-random-value

# Optional — enables the /simulator UI; leave unset in production to disable
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
SIMULATOR_KEY=
